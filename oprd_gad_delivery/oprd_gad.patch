+def compute_discriminator_loss(
+    student_vpreds: torch.Tensor,
+    teacher_vpreds: torch.Tensor,
+    response_mask: torch.Tensor,
+    teacher_response_mask: torch.Tensor,
+) -> torch.Tensor:
+    """Bradley-Terry discriminator loss for GAD (Generative Adversarial Distillation).
+
+    The critic is hacked into a discriminator: it emits a per-token scalar, of which only
+    the last real response token is kept (all others zeroed upstream in dp_critic). Summing
+    over the response therefore yields a single sequence-level score D(y). This loss trains the
+    discriminator to score the teacher response higher than the student response:
+
+        L_D = - E[ log sigmoid( D(y_teacher) - D(y_student) ) ]
+
+    Args:
+        student_vpreds (torch.Tensor): (bsz, response_length) student per-token scores
+            (nonzero only at the last real token).
+        teacher_vpreds (torch.Tensor): (bsz, teacher_response_length) teacher per-token scores.
+        response_mask (torch.Tensor): (bsz, response_length) student response mask.
+        teacher_response_mask (torch.Tensor): (bsz, teacher_response_length) teacher response mask.
+
+    Returns:
+        torch.Tensor: scalar Bradley-Terry discriminator loss.
+    """
+    teacher_reward = torch.sum(teacher_vpreds * teacher_response_mask, dim=-1)
+    student_reward = torch.sum(student_vpreds * response_mask, dim=-1)
+    d_loss = -torch.nn.functional.logsigmoid(teacher_reward - student_reward).mean()
+    return d_loss
+
+
